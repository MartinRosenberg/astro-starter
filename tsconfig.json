{
	"extends": "astro/tsconfigs/strict",
	"exclude": [
		"dist/"
	],
	"include": [
		".astro/types.d.ts",
		"**/*"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"paths": {
			"#*": [
				"src/*"
			]
		},
		"plugins": [
			{
				"name": "@astrojs/ts-plugin"
			}
		],
		"verbatimModuleSyntax": true
	}
}
